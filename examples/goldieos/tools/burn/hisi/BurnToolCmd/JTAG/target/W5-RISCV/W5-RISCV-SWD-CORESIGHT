# USAGE:
# cmd: telnet localhost 4444

# enable coresight-swd mode
# mww 0x40010260 1

adapter speed 3
transport select swd

gdb_port disabled
tcl_port disabled

set  _CHIPNAME linxcore131
set _CPUTAPID 0x5ba00477
set  _ENDIAN little


#jtag newtap $_CHIPNAME cpu -irlen 5 -expected-id $_CPUTAPID
#swd newdap $_CHIPNAME cpu -irlen 4 -expected-id $_CPUTAPID
swd newdap $_CHIPNAME cpu -irlen 5 -ircapture 0x1 -irmask 0x0f -expected-id $_CPUTAPID
# irlen 5, capture: 0x1 mask: 0x3
# -ircapture 0x1 -irmask 0x0f
# -ircapture 0x1f -irmask 0x0f
# -ircapture 0x0f

dap create $_CHIPNAME.dap -chain-position $_CHIPNAME.cpu
set _TARGETNAME $_CHIPNAME.cpu
target create $_TARGETNAME riscvcs -endian $_ENDIAN -apsel 0 -dap $_CHIPNAME.dap -dbgbase 0x80000000


# 0X7c0~0x7cf 2008=7d8
#riscv expose_csrs 932-943,1984-1999,2008
#riscv set_prefer_sba off

init
halt
resume 0x100000
halt