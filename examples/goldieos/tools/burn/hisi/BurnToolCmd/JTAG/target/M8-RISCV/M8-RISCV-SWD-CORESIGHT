# erase whole flash chip
mww 0x40800308 0x6
mww 0x40800300 0x3 
mww 0x40800308 0xC7
mww 0x40800300 0x3
sleep 6000

set LOAD_ADDR 0x400000
set LOAD_FILE "load_dump\\SWD-demo_burn.bin"
set DUMP_FILE "load_dump\\SWD-demo_burn-dump.bin"

set FILESIZE [file size $LOAD_FILE]

load_image $LOAD_FILE $LOAD_ADDR bin
dump_image $DUMP_FILE $LOAD_ADDR $FILESIZE
}

