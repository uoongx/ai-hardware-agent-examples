# USAGE:
# cmd: telnet localhost 4444

# enable coresight-swd mode
# mww 0x40010260 1

adapter speed 500
transport select swd

set  _CHIPNAME linxcore131
set _CPUTAPID 0x5ba00477
set  _ENDIAN little

#jtag newtap $_CHIPNAME cpu -irlen 5 -expected-id $_CPUTAPID
swd newdap $_CHIPNAME cpu -irlen 4 -expected-id $_CPUTAPID
# irlen 5, capture: 0x1 mask: 0x3
# -ircapture 0x1 -irmask 0x0f
# -ircapture 0x1f -irmask 0x0f
# -ircapture 0x0f

dap create $_CHIPNAME.dap -chain-position $_CHIPNAME.cpu
set _TARGETNAME $_CHIPNAME.cpu
target create $_TARGETNAME riscvcs -endian $_ENDIAN -apsel 0 -dap $_CHIPNAME.dap -dbgbase 0x80000000


# 0X7c0~0x7cf 2008=7d8
riscv expose_csrs 932-943,1984-1999,2008
riscv set_prefer_sba off

init
halt
# If load_image fails, reduce the FREQUENCY
adapter speed 2000
# 15000 may ok

# load bin to the FLASH, maybe 0x400000
proc load_bin {firmwarefile addr} {
reset halt
# Close I/D Cache
reg csr0x7c0 0
reg csr0x7c1 0

# reset SFC
mww 0x4001003c 0x1fe3
mww 0x4001003c 0x1fff
sleep 10

# enable flash write
mww 0x40800200 0xC080EB1E

# erase whole flash chip
mww 0x40800308 0x6
mww 0x40800300 0x3 
mww 0x40800308 0xC7
mww 0x40800300 0x3
sleep 6000

load_image $firmwarefile $addr bin
echo "load burn.bin successful"
}

proc flash_erase { } {
reset halt
# Close I/D Cache
reg csr0x7c0 0
reg csr0x7c1 0

# enable flash write
mww 0x40800200 0xC080EB1E

# erase whole flash chip
mww 0x40800308 0x6
mww 0x40800300 0x3 
mww 0x40800308 0xC7
mww 0x40800300 0x3
sleep 6000
}

proc flash_protect { } {
# disable flash write
mww 0x40800200 0x8080EB1E
}

proc load_bin_erase { } {
reset halt
# Close I/D Cache
reg csr0x7c0 0
reg csr0x7c1 0

# reset SFC
